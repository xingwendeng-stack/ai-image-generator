# ===== 提供商选择 =====
# huggingface - 免费（推荐，只需免费注册获取 token）
# demo       - 无需任何 API Key，直接生成占位图测试界面
# openai     - 付费（需要 OpenAI API Key）
# demo - 无需 API Key 即可测试界面
# huggingface - 免费生成真实图片（需配置 HF_API_TOKEN）
PROVIDER=huggingface

# ===== Hugging Face (免费) 配置 =====
# 注册: https://huggingface.co/ → Settings → Access Tokens → 创建 token
# 免费额度: 每天数万次调用，完全免费
HF_API_TOKEN=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

# 可用模型: flux-schnell（最快）, sd-xl, sd-3.5, sd-2
# flux-schnell 推荐（速度快、质量高）
HF_MODEL=flux-schnell

# ===== OpenAI (付费) 配置 =====
# OPENAI_API_KEY=sk-your-openai-api-key
# OPENAI_MODEL=dall-e-3
# IMAGE_SIZE=1024x1024
